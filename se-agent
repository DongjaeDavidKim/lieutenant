#!/bin/bash
# se-agent — Lieutenant: spawn SE agents and validators in tmux windows with claude sessions
#
# Usage:
#   se-agent spawn FLOW-123 --repo ~/workspace/src/flow --base development \
#     --summary "Add payment retry logic" --criteria "- Retry on 5xx\n- Max 3 attempts"
#
#   se-agent validate FLOW-123 --repo ~/workspace/src/flow
#
#   se-agent dashboard          # Launch the dashboard
#   se-agent init               # Create tmux swarm session
#   se-agent status             # Quick status of all agents
#   se-agent list               # List active agent windows

set -euo pipefail

SWARM_SESSION="swarm"
DASHBOARD_PY="$HOME/.lieutenant/dashboard.py"
SWARM_BASE="$HOME/.micolash/swarm"
STATE_FILE="$HOME/.lieutenant/state.md"
PORT_FILE="$HOME/.lieutenant/.port"

# ─── Helpers ────────────────────────────────────────────────────────────────

ensure_tmux_session() {
  if ! tmux has-session -t "$SWARM_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SWARM_SESSION" -n orchestrator
    echo "Created tmux session: $SWARM_SESSION"
  fi
}

get_dashboard_port() {
  if [[ -f "$PORT_FILE" ]]; then
    cat "$PORT_FILE"
  else
    echo ""
  fi
}

get_dashboard_url() {
  local port
  port="$(get_dashboard_port)"
  if [[ -n "$port" ]]; then
    echo "http://localhost:$port"
  else
    echo "http://localhost:<unknown — dashboard not running>"
  fi
}

# Write/refresh state.md with current session topology
write_state() {
  local port
  port="$(get_dashboard_port)"

  # Resolve active plan path
  local plan_path=""
  if [[ -f "$HOME/.lieutenant/.plan_path" ]]; then
    plan_path="$(cat "$HOME/.lieutenant/.plan_path")"
  elif [[ -f "$HOME/.lieutenant/plan.md" ]]; then
    plan_path="$HOME/.lieutenant/plan.md"
  fi

  {
    echo "# Lieutenant State"
    echo ""
    echo "_Auto-generated by lieutenant. Do not edit while running._"
    echo ""
    echo "## Orchestrator"
    echo ""
    echo "- **tmux session:** \`$SWARM_SESSION\`"
    echo "- **dashboard port:** \`${port:-not running}\`"
    echo "- **plan:** \`${plan_path:-none}\`"
    echo "- **updated:** \`$(date -u +%Y-%m-%dT%H:%M:%SZ)\`"
    echo ""
    echo "## Agents"
    echo ""
    echo "| window | pane pid | cage | branch | worktree | cwd |"
    echo "|--------|----------|------|--------|----------|-----|"

    if tmux has-session -t "$SWARM_SESSION" 2>/dev/null; then
      tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}	#{pane_pid}	#{pane_current_path}' 2>/dev/null | while IFS=$'\t' read -r wname ppid cwd; do
        case "$wname" in
          se/*|val/*)
            ticket="${wname#*/}"
            cage_dir="$HOME/.micolash/cages/$ticket"
            cage_ws="$cage_dir/workspace"
            cage="no"
            branch="-"
            worktree="-"
            if [[ -d "$cage_ws" ]]; then
              cage="$ticket"
              worktree="$cage_ws"
              # Get branch from the worktree
              branch="$(git -C "$cage_ws" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '-')"
            elif [[ -d "$cwd/.git" || -f "$cwd/.git" ]]; then
              # Not in a cage but in a git repo — get branch anyway
              branch="$(git -C "$cwd" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '-')"
            fi
            echo "| \`$wname\` | \`$ppid\` | \`$cage\` | \`$branch\` | \`$worktree\` | \`$cwd\` |"
            ;;
        esac
      done
    fi

    echo ""
  } > "$STATE_FILE"
}

# ─── Commands ───────────────────────────────────────────────────────────────

cmd_init() {
  local plan=""
  local permission_mode="default"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan="$2"; shift 2;;
      --permission-mode) permission_mode="$2"; shift 2;;
      *) shift;;
    esac
  done

  ensure_tmux_session
  echo "Swarm session ready: $SWARM_SESSION"
  echo "  tmux attach -t $SWARM_SESSION"

  if [[ -n "$plan" ]]; then
    echo "Plan: $plan"
    echo "$plan" > "$HOME/.lieutenant/.plan_path"
  fi

  # Resolve plan for the orchestrator prompt
  local plan_path="${plan:-}"
  if [[ -z "$plan_path" && -f "$HOME/.lieutenant/.plan_path" ]]; then
    plan_path="$(cat "$HOME/.lieutenant/.plan_path")"
  fi
  if [[ -z "$plan_path" ]]; then
    plan_path="$HOME/.lieutenant/plan.md"
  fi

  local plan_content=""
  if [[ -f "$plan_path" ]]; then
    plan_content="$(cat "$plan_path")"
  fi

  # Build orchestrator system prompt
  local system_prompt="You are the Lieutenant Orchestrator — you manage a swarm of SE agents working on sub-tasks.

## Your Tools

You run inside a tmux session called '$SWARM_SESSION'. You can:
- Spawn agents:    \`se-agent spawn TICKET --repo PATH --base BRANCH --summary '...' --criteria '...'\`
- Spawn validators: \`se-agent validate TICKET --repo PATH\`
- Check status:     \`se-agent status\` or \`se-agent list\`
- Kill agents:      \`se-agent kill TICKET\` or \`se-agent kill-all\`
- View state:       \`cat $STATE_FILE\`
- View agent logs:  \`tmux capture-pane -t $SWARM_SESSION:se/TICKET -p\`

## Current Plan

\`\`\`
${plan_content:-No plan loaded. Ask the user what to work on.}
\`\`\`

## Instructions

1. Read the plan above. Break it into sub-tasks if not already done.
2. For each sub-task, spawn an SE agent with clear acceptance criteria.
3. Monitor agent progress by reading their tmux panes.
4. When an agent reports done, spawn a validator to attack its changes.
5. If a validator finds issues, relay them back to the SE agent.
6. When all sub-tasks pass validation, summarize the results and ask the user for next steps.

## Rules
- One agent per sub-task. Don't overload.
- Always use cages — pass --repo so the agent gets its own worktree.
- Keep the user informed of progress. Be concise.
- If an agent is stuck for more than 2 check-ins, kill it and try a different approach.
- Never push or create PRs without user approval."

  # Write prompt to file to avoid quoting issues
  local run_dir="$SWARM_BASE/$(date +%Y%m%d)"
  mkdir -p "$run_dir"
  local prompt_file="$run_dir/orchestrator-prompt.txt"
  echo "$system_prompt" > "$prompt_file"

  # Enable transcript logging for orchestrator
  tmux pipe-pane -t "$SWARM_SESSION:orchestrator" -o \
    "cat >> $run_dir/orchestrator-transcript.log"

  # Launch Claude in the orchestrator window — fully autonomous, from lieutenant dir
  tmux send-keys -t "$SWARM_SESSION:orchestrator" \
    "cd '$HOME/.lieutenant' && claude --dangerously-skip-permissions --system-prompt \"\$(cat '$prompt_file')\"" Enter

  echo "Orchestrator Claude session launched"
}

cmd_dashboard() {
  local plan=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan="$2"; shift 2;;
      *) shift;;
    esac
  done

  # Kill existing dashboard if running
  pkill -f "python3.*dashboard.py" 2>/dev/null || true
  sleep 0.5

  # Resolve plan path: explicit arg > stored path > default
  if [[ -z "$plan" && -f "$HOME/.lieutenant/.plan_path" ]]; then
    plan="$(cat "$HOME/.lieutenant/.plan_path")"
  fi

  # Launch dashboard in background (random port unless --port specified)
  local plan_arg=""
  if [[ -n "$plan" ]]; then
    plan_arg="--plan $plan"
  fi
  python3 "$DASHBOARD_PY" $plan_arg &
  DASH_PID=$!
  echo "$DASH_PID" > "$HOME/.lieutenant/dashboard.pid"
  echo "Dashboard started (PID $DASH_PID)"

  # Wait for the port file to appear (dashboard writes it on startup)
  local tries=0
  while [[ ! -f "$PORT_FILE" ]] && (( tries < 10 )); do
    sleep 0.3
    tries=$((tries + 1))
  done

  local url
  url="$(get_dashboard_url)"
  echo "Dashboard: $url"

  # Open in browser on macOS
  if [[ -f "$PORT_FILE" ]]; then
    open "$url" 2>/dev/null || echo "Open $url"
  fi

  # Write initial state
  write_state
}

cmd_spawn() {
  local ticket="$1"; shift
  local repo=""
  local base="development"
  local summary=""
  local criteria=""
  local permission_mode="default"
  local system_prompt=""

  local plan=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) repo="$2"; shift 2;;
      --base) base="$2"; shift 2;;
      --summary) summary="$2"; shift 2;;
      --criteria) criteria="$2"; shift 2;;
      --plan) plan="$2"; shift 2;;
      --permission-mode) permission_mode="$2"; shift 2;;
      --system-prompt) system_prompt="$2"; shift 2;;
      *) echo "Unknown arg: $1"; exit 1;;
    esac
  done

  # If plan provided but no summary/criteria, extract from plan file
  if [[ -n "$plan" && -f "$plan" && -z "$summary" ]]; then
    summary="See plan file for full context"
    criteria="$(cat "$plan")"
  fi

  if [[ -z "$ticket" ]]; then
    echo "Usage: se-agent spawn FLOW-123 --repo <path> [--summary ...] [--criteria ...]"
    exit 1
  fi

  ensure_tmux_session

  local window_name="se/$ticket"

  # Check if window already exists
  if tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window_name}$"; then
    echo "Agent window $window_name already exists"
    exit 1
  fi

  # Create cage if repo is specified and cage doesn't exist
  if [[ -n "$repo" ]]; then
    if ! cage list 2>/dev/null | grep -q "$ticket"; then
      echo "Creating cage: $ticket"
      cage create "$ticket" --repo "$repo" --branch "$base"
    fi
  fi

  # Determine working directory
  local workdir="$HOME/.micolash/cages/$ticket/workspace"
  if [[ ! -d "$workdir" ]]; then
    workdir="${repo:-$HOME}"
  fi

  # Build system prompt if not provided
  if [[ -z "$system_prompt" ]]; then
    system_prompt="You are SE Agent '$ticket'. Your mission is to implement this Jira ticket autonomously.

Ticket: $ticket
Summary: ${summary:-No summary provided — fetch from Jira}

Acceptance Criteria:
${criteria:-Fetch from Jira ticket $ticket}

Working Directory: $workdir

Instructions:
1. If acceptance criteria are missing above, fetch them from Jira first
2. Read the relevant code in your workspace
3. Implement the changes described in the acceptance criteria
4. Write or update tests
5. Commit with message format: $ticket: <what and why>
6. When done, report what you changed and confirm all criteria are met
7. Wait for the orchestrator to approve before pushing or creating a PR

Constraints:
- Only modify files in your workspace
- Keep changes minimal and focused
- If stuck after 2 attempts, describe the blocker and wait for guidance
- Do not push or create PRs unless told to"
  fi

  # Create tmux window for the claude agent
  tmux new-window -t "$SWARM_SESSION" -n "$window_name"

  # Create a companion terminal window (plain bash in the same cage)
  local term_window="term/${ticket}"
  tmux new-window -t "$SWARM_SESSION" -n "$term_window"
  tmux send-keys -t "$SWARM_SESSION:$term_window" "cd '$workdir'" Enter

  # Enable pane logging for the watcher
  local run_dir="$SWARM_BASE/$(date +%Y%m%d)"
  mkdir -p "$run_dir/agents/$ticket"
  tmux pipe-pane -t "$SWARM_SESSION:$window_name" -o \
    "cat >> $run_dir/agents/$ticket/transcript.log"

  # Write system prompt to file (avoids shell quoting issues with tmux send-keys)
  local prompt_file="$run_dir/agents/$ticket/system-prompt.txt"
  echo "$system_prompt" > "$prompt_file"

  # Launch claude in the agent window — fully autonomous
  tmux send-keys -t "$SWARM_SESSION:$window_name" \
    "cd '$workdir' && claude --dangerously-skip-permissions --system-prompt \"\$(cat '$prompt_file')\"" Enter

  echo "Spawned $window_name in tmux session $SWARM_SESSION"
  echo "  Terminal: $term_window (bash in $workdir)"
  echo "  Mode: dangerously-skip-permissions"

  # Update state file
  write_state
}

cmd_validate() {
  local ticket="$1"; shift
  local repo=""
  local permission_mode="default"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) repo="$2"; shift 2;;
      --permission-mode) permission_mode="$2"; shift 2;;
      *) echo "Unknown arg: $1"; exit 1;;
    esac
  done

  if [[ -z "$ticket" ]]; then
    echo "Usage: se-agent validate FLOW-123 [--repo <path>]"
    exit 1
  fi

  ensure_tmux_session

  local window_name="val/$ticket"

  if tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window_name}$"; then
    echo "Validator window $window_name already exists"
    exit 1
  fi

  # Determine working directory — prefer cage workspace, fall back to repo
  local workdir="$HOME/.micolash/cages/$ticket/workspace"
  if [[ ! -d "$workdir" ]]; then
    workdir="${repo:-$HOME}"
  fi

  local system_prompt="You are an ADVERSARIAL VALIDATOR for ticket '$ticket'.

Your job is to ATTACK the code changes in this workspace. You are hostile — assume everything is wrong until proven right with quantitative evidence.

Working Directory: $workdir

## Attack Protocol

1. Run 'git diff --stat' and 'git diff' to see what changed
2. Run 'git log --oneline -10' to see commit messages / stated outcomes
3. For EACH changed file:
   a. Classify risk: TIER 1 (trivial), TIER 2 (prove it), TIER 3 (guilty until innocent)
   b. Grep for callers of changed functions — count them
   c. Check if tests exist — run them, report pass/fail counts
   d. Look for hallucinated imports, non-existent APIs, wrong method signatures
   e. Check error handling, null cases, concurrent access

4. Issue challenges in this format:
   [TIER X] CHALLENGE: <description>
   FILE: <path>:<line>
   CLAIM: <what the code implies>
   QUANTITATIVE EVIDENCE: <command output, counts, test results>
   VERDICT: WRONG | UNVERIFIED | SUSPICIOUS | CONFIRMED
   ACTION: <what must be done>

5. End with a summary:
   Total challenges: N
     WRONG: n
     UNVERIFIED: n
     SUSPICIOUS: n
     CONFIRMED: n
   Risk assessment: BLOCK | REVIEW | PASS

## Rules
- CONFIRMED requires a test passing or a grep count proving the claim
- 'Looks correct' is NOT evidence — run a command, get a number
- For TIER 3 files (auth, payments, infra, migrations): guilty until proven innocent
- You are scoped to THIS diff only — don't go on tangents"

  # Create tmux window for the validator
  tmux new-window -t "$SWARM_SESSION" -n "$window_name"

  # Create a companion terminal window (plain bash in the same cage)
  local term_window="term/${ticket}"
  if ! tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${term_window}$"; then
    tmux new-window -t "$SWARM_SESSION" -n "$term_window"
    tmux send-keys -t "$SWARM_SESSION:$term_window" "cd '$workdir'" Enter
  fi

  # Enable pane logging
  local run_dir="$SWARM_BASE/$(date +%Y%m%d)"
  mkdir -p "$run_dir/validators/$ticket"
  tmux pipe-pane -t "$SWARM_SESSION:$window_name" -o \
    "cat >> $run_dir/validators/$ticket/transcript.log"

  # Write system prompt to file (avoids shell quoting issues with tmux send-keys)
  local prompt_file="$run_dir/validators/$ticket/system-prompt.txt"
  echo "$system_prompt" > "$prompt_file"

  # Launch claude — fully autonomous
  tmux send-keys -t "$SWARM_SESSION:$window_name" \
    "cd '$workdir' && claude --dangerously-skip-permissions --system-prompt \"\$(cat '$prompt_file')\"" Enter

  echo "Spawned validator $window_name"
  echo "  Working dir: $workdir"
  echo "  Attacking: $ticket"

  # Update state file
  write_state
}

cmd_status() {
  if ! tmux has-session -t "$SWARM_SESSION" 2>/dev/null; then
    echo "No swarm session running"
    exit 0
  fi

  echo "Swarm windows:"
  tmux list-windows -t "$SWARM_SESSION" -F '  #{window_name}  #{window_activity_string}' 2>/dev/null
}

cmd_list() {
  if ! tmux has-session -t "$SWARM_SESSION" 2>/dev/null; then
    echo "No swarm session"
    exit 0
  fi
  tmux list-windows -t "$SWARM_SESSION" -F '#{window_index}: #{window_name}' 2>/dev/null | grep -E "^[0-9]+: (se|val)/"
}

cmd_kill() {
  local ticket="$1"
  # Try se/ first, then val/
  local window_name=""
  for prefix in se val; do
    if tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${prefix}/${ticket}$"; then
      window_name="${prefix}/${ticket}"
      break
    fi
  done
  if [[ -z "$window_name" ]]; then
    echo "No window found for $ticket"
    exit 1
  fi
  tmux send-keys -t "$SWARM_SESSION:$window_name" C-c "" 2>/dev/null
  sleep 0.5
  tmux send-keys -t "$SWARM_SESSION:$window_name" "/exit" Enter 2>/dev/null
  sleep 1
  tmux kill-window -t "$SWARM_SESSION:$window_name" 2>/dev/null
  # Also kill companion terminal window
  tmux kill-window -t "$SWARM_SESSION:term/$ticket" 2>/dev/null
  echo "Killed $window_name (and term/$ticket)"
  write_state
}

cmd_kill_all() {
  for win in $(tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -E "^(se|val)/"); do
    tmux send-keys -t "$SWARM_SESSION:$win" C-c "" 2>/dev/null
    sleep 0.3
    tmux send-keys -t "$SWARM_SESSION:$win" "/exit" Enter 2>/dev/null
  done
  sleep 1
  for win in $(tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -E "^(se|val)/"); do
    tmux kill-window -t "$SWARM_SESSION:$win" 2>/dev/null
  done
  echo "All agents and validators killed"
  write_state
}

cmd_recover() {
  echo "Recovering lieutenant state..."

  if [[ ! -f "$STATE_FILE" ]]; then
    echo "No state file found at $STATE_FILE — nothing to recover"
    exit 1
  fi

  echo "State file: $STATE_FILE"
  cat "$STATE_FILE"
  echo ""

  # Check if tmux swarm session exists
  if tmux has-session -t "$SWARM_SESSION" 2>/dev/null; then
    echo "Tmux session '$SWARM_SESSION' is alive."
  else
    echo "Tmux session '$SWARM_SESSION' is GONE. Recreating..."
    tmux new-session -d -s "$SWARM_SESSION" -n orchestrator
    echo "  Created fresh session."
  fi

  # Check which agents from state are still alive vs need respawn
  local recovered=0
  local missing=0

  # Parse agent rows from state.md (lines matching | `se/...` or | `val/...`)
  while IFS= read -r line; do
    # Extract window name from markdown table row
    local wname
    wname=$(echo "$line" | sed -n 's/^| `\(se\/[^`]*\|val\/[^`]*\)`.*/\1/p')
    [[ -z "$wname" ]] && continue

    local ticket="${wname#*/}"

    if tmux list-windows -t "$SWARM_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${wname}$"; then
      echo "  ✓ $wname — still alive in tmux"
      recovered=$((recovered + 1))
    else
      echo "  ✗ $wname — tmux window gone"
      # Check if cage still exists for potential respawn
      local cage_dir="$HOME/.micolash/cages/$ticket/workspace"
      if [[ -d "$cage_dir" ]]; then
        echo "    cage exists at $cage_dir — can respawn with:"
        echo "    se-agent spawn $ticket --repo <original-repo>"
      else
        echo "    no cage found — agent work may be lost"
      fi
      missing=$((missing + 1))
    fi
  done < "$STATE_FILE"

  echo ""
  echo "Recovery summary: $recovered alive, $missing missing"

  # Check dashboard
  if [[ -f "$PORT_FILE" ]]; then
    local port
    port="$(cat "$PORT_FILE")"
    if curl -s "http://localhost:$port/api/agents" >/dev/null 2>&1; then
      echo "Dashboard is running at http://localhost:$port"
    else
      echo "Dashboard port file exists ($port) but not responding — restart with: se-agent dashboard"
      rm -f "$PORT_FILE"
    fi
  else
    echo "Dashboard not running — start with: se-agent dashboard"
  fi

  # Refresh state
  write_state
}

# ─── Main ───────────────────────────────────────────────────────────────────

case "${1:-help}" in
  init)      shift; cmd_init "$@" ;;
  dashboard) shift; cmd_dashboard "$@" ;;
  spawn)     shift; cmd_spawn "$@" ;;
  validate)  shift; cmd_validate "$@" ;;
  status)    cmd_status ;;
  list)      cmd_list ;;
  kill)      shift; cmd_kill "$@" ;;
  kill-all)  cmd_kill_all ;;
  recover)   cmd_recover ;;
  help|*)
    echo "se-agent — Lieutenant Agent Manager"
    echo ""
    echo "Commands:"
    echo "  init [--plan FILE]      Create tmux swarm session"
    echo "  dashboard [--plan FILE] Launch web dashboard"
    echo "  spawn TICKET [opts]     Spawn an SE agent for a sub-task"
    echo "  validate TICKET [opts]  Spawn a validator to attack a ticket's changes"
    echo "  status                  Quick status of all windows"
    echo "  list                    List active agent/validator windows"
    echo "  kill TICKET             Kill an agent or validator"
    echo "  kill-all                Kill all agents and validators"
    echo "  recover                 Recover from crash using state.md"
    echo ""
    echo "Spawn options:"
    echo "  --repo PATH             Repository path"
    echo "  --base BRANCH           Base branch (default: development)"
    echo "  --summary TEXT           Ticket summary"
    echo "  --criteria TEXT          Acceptance criteria"
    echo "  --permission-mode MODE  Claude permission mode (default: default)"
    ;;
esac
